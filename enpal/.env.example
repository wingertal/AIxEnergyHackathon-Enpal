# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit real secrets.

# --- App ---
APP_ENV=development            # development | production
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- AI layer (chatbot) ---
# The conversational companion (merged-in chatbot) runs on OpenAI. Without a key
# it falls back to deterministic, data-grounded answers (still fully functional).
# Get a key from https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Conversation persistence (chatbot history) ---
# SQLite by default; point at Postgres in production.
DATABASE_URL=sqlite:///./enpal_chat.db

# --- External data (optional, for forecast feature) ---
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1
