# ============================================================
# Smart Energy Companion - monorepo root ignore
# (each subproject also keeps its own .gitignore)
# ============================================================

# --- Secrets / env ---
.env
.env.*
!.env.example
!.env.local.example
!*.example

# --- Python (backend: enpal/) ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- SQLite databases (chatbot history) ---
*.db
*.sqlite
*.sqlite3

# --- Node / Next.js (frontend: smart-energy-companion/) ---
node_modules/
.next/
out/
build/
.vercel/
*.tsbuildinfo
next-env.d.ts
.pnp.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/

# --- Large archives / build artifacts ---
*.zip

# --- Claude Code session data ---
.claude/

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store
Thumbs.db
*.pem
